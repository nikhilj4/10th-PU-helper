APP_ENV=development
APP_NAME=student-chatbot-api
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

OPENAI_API_KEY=
